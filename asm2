#include <stdio.h>
#include <math.h>
#include <stdlib.h>
#include <time.h>

int main() {

    int chon;

    do {

        printf("\n===== MENU =====\n");
        printf("1. Kiem tra so\n");
        printf("2. UCLN BCNN\n");
        printf("3. Karaoke\n");
        printf("4. Tien dien\n");
        printf("5. Doi tien\n");
        printf("6. Lai suat\n");
        printf("7. Vay mua xe\n");
        printf("8. Sinh vien\n");
        printf("9. FPOLY LOTT\n");
        printf("10. Phan so\n");
        printf("0. Thoat\n");

        scanf("%d", &chon);

        switch (chon) {

        // 1
        case 1: {
            int x,i,nt=1;

            scanf("%d",&x);

            if(x<2) nt=0;

            for(i=2;i<x;i++)
                if(x%i==0) nt=0;

            if(nt) printf("Nguyen to\n");
            else printf("Khong\n");

            int a=sqrt(x);

            if(a*a==x) printf("Chinh phuong\n");
            else printf("Khong\n");

            break;
        }

        // 2
        case 2: {
            int x,y,a,b;

            scanf("%d%d",&x,&y);

            a=x; b=y;

            while(a!=b){
                if(a>b) a-=b;
                else b-=a;
            }

            printf("UCLN=%d\n",a);
            printf("BCNN=%d\n",(x*y)/a);

            break;
        }

        // 3
        case 3: {
            int bd,kt;
            float tien;

            scanf("%d%d",&bd,&kt);

            int gio=kt-bd;

            if(gio<=3)
                tien=gio*150000;
            else
                tien=3*150000+(gio-3)*150000*0.7;

            if(bd>=14 && bd<=17)
                tien*=0.9;

            printf("%.0f\n",tien);

            break;
        }

        // 4
        case 4: {
            int kwh;
            float tien=0;

            scanf("%d",&kwh);

            if(kwh<=50)
                tien=kwh*1678;

            else if(kwh<=100)
                tien=50*1678+(kwh-50)*1734;

            else if(kwh<=200)
                tien=50*1678+50*1734+(kwh-100)*2014;

            else if(kwh<=300)
                tien=50*1678+50*1734+100*2014+(kwh-200)*2536;

            else
                tien=500000;

            printf("%.0f\n",tien);

            break;
        }

        // 5
        case 5: {
            int t;
            scanf("%d",&t);

            int m[9]={500,200,100,50,20,10,5,2,1};

            for(int i=0;i<9;i++){
                printf("%d : %d\n",m[i],t/m[i]);
                t%=m[i];
            }

            break;
        }

        // 6
        case 6: {
            float tien;
            scanf("%f",&tien);

            float lai=0.05;

            for(int i=1;i<=12;i++){

                float tra=tien/12+tien*lai;

                printf("Thang %d: %.0f\n",i,tra);

                tien-=tien/12;
            }

            break;
        }

        // 7
        case 7: {
            float pt;

            scanf("%f",&pt);

            float gia=500000000;

            float vay=gia*pt/100;

            printf("Tra truoc %.0f\n",gia-vay);

            float lai=0.072/12;

            for(int i=1;i<=24;i++){

                float tra=vay/24+vay*lai;

                printf("Thang %d %.0f\n",i,tra);

                vay-=vay/24;
            }

            break;
        }

        // 8
        case 8: {

            int n;
            scanf("%d",&n);

            float d[50];

            for(int i=0;i<n;i++)
                scanf("%f",&d[i]);

            for(int i=0;i<n;i++)
            for(int j=i+1;j<n;j++)
                if(d[i]<d[j]){
                    float t=d[i];
                    d[i]=d[j];
                    d[j]=t;
                }

            for(int i=0;i<n;i++){

                printf("%.1f ",d[i]);

                if(d[i]>=9) printf("XS\n");
                else if(d[i]>=8) printf("Gioi\n");
                else if(d[i]>=6.5) printf("Kha\n");
                else if(d[i]>=5) printf("TB\n");
                else printf("Yeu\n");
            }

            break;
        }

        // 9
        case 9: {

            srand(time(0));

            int a,b;

            scanf("%d%d",&a,&b);

            int x=rand()%15+1;
            int y=rand()%15+1;

            int dung=0;

            if(a==x||a==y) dung++;
            if(b==x||b==y) dung++;

            if(dung==2) printf("Giai nhat\n");
            else if(dung==1) printf("Giai nhi\n");
            else printf("Chuc may man\n");

            break;
        }

        // 10
        case 10: {

            int a,b,c,d;

            scanf("%d%d%d%d",&a,&b,&c,&d);

            printf("Tong %d/%d\n",a*d+b*c,b*d);
            printf("Hieu %d/%d\n",a*d-b*c,b*d);
            printf("Tich %d/%d\n",a*c,b*d);
            printf("Thuong %d/%d\n",a*d,b*c);

            break;
        }

        }

    } while(chon!=0);

}